DATABASE_URL=sqlite:///./app.db
# REQUIRED — set a long random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
MAX_PIXELS=8000000
RATE_LIMIT_PER_MINUTE=60
MODEL_VARIANT_DEFAULT=int8_static_640
DEBUG=true
MOCK_INFERENCE=true
